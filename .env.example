# =============================================================================
# Audio Inmersivo - Variables de entorno
# Copia este archivo a .env y ajusta los valores. NUNCA commitees .env
# =============================================================================

# --- General ---------------------------------------------------------------
# development | production
APP_ENV=development
APP_NAME="Audio Inmersivo"
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:3000

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_USER=audio_admin
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=audio_inmersivo
# En Docker el backend usa el host "postgres"; fuera de Docker usa localhost
DATABASE_URL=postgresql://audio_admin:change-me-strong-password@localhost:5432/audio_inmersivo

# --- Redis / Celery ----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_CONCURRENCY=2

# --- MinIO (S3-compatible) ---------------------------------------------------
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change-me-strong-password
MINIO_ENDPOINT=localhost:9000
# Endpoint de MinIO visible desde el navegador (URLs prefirmadas).
# En producción: dominio público de MinIO (p. ej. media.tudominio.com)
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_BUCKET_AUDIO=audios
# true solo si MinIO está detrás de TLS
MINIO_USE_SSL=false

# --- Seguridad / JWT ---------------------------------------------------------
# Genera uno con: openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Superadmin inicial (seed) -------------------------------------------------
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me-strong-password

# --- Límites de procesamiento --------------------------------------------------
# Tamaño máximo de subida en MB
MAX_UPLOAD_SIZE_MB=200
# Duración máxima de audio en segundos (0 = sin límite)
MAX_AUDIO_DURATION_SECONDS=3600
# Formatos de entrada permitidos (separados por coma)
ALLOWED_AUDIO_FORMATS=mp3,wav,flac,m4a,ogg,aac,opus,wma
# Modelo Demucs para separación de fuentes (htdemucs | htdemucs_6s | htdemucs_ft)
DEMUCS_MODEL=htdemucs

# --- Frontend ------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
