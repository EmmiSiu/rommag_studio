# Production template for Easypanel. Copy values into Easypanel secrets.

APP_ENV=production
APP_NAME="Audio Inmersivo"
CORS_ORIGINS=https://audio.example.com

POSTGRES_USER=audio_prod
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_SECRET
POSTGRES_DB=audio_inmersivo

REDIS_URL=redis://redis:6379/0
CELERY_CONCURRENCY=1

MINIO_ROOT_USER=audio_minio
MINIO_ROOT_PASSWORD=REPLACE_WITH_STRONG_SECRET
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=media.audio.example.com
MINIO_BUCKET_AUDIO=audios
MINIO_USE_SSL=true

JWT_SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=REPLACE_WITH_STRONG_SECRET

MAX_UPLOAD_SIZE_MB=200
MAX_AUDIO_DURATION_SECONDS=3600
ALLOWED_AUDIO_FORMATS=mp3,wav,flac,m4a,ogg,aac,opus,wma
DEMUCS_MODEL=htdemucs

NEXT_PUBLIC_API_URL=https://api.audio.example.com
